/* ═══════════════════════════════════════════════════
   IONIC CORE — obligatorio, va PRIMERO
═══════════════════════════════════════════════════ */
@use "@ionic/angular/css/core.css";
@use "@ionic/angular/css/normalize.css";
@use "@ionic/angular/css/structure.css";
@use "@ionic/angular/css/typography.css";
@use "@ionic/angular/css/display.css";

/* Utilities opcionales de Ionic */
@use "@ionic/angular/css/padding.css";
@use "@ionic/angular/css/float-elements.css";
@use "@ionic/angular/css/text-alignment.css";

/* ═══════════════════════════════════════════════════
   VARIABLES FENIXBD
═══════════════════════════════════════════════════ */
:root {
  --ion-font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
  --ion-background-color: #f8fafc;
  --ion-text-color: #0f172a;
  --ion-toolbar-background: #ffffff;
  --ion-toolbar-border-color: #e2e8f0;
  --ion-color-primary: #e11d48;
  --ion-color-primary-rgb: 225, 29, 72;
  --ion-color-primary-contrast: #ffffff;
  --ion-color-primary-shade: #c71a40;
  --ion-color-primary-tint: #e4345a;
}

/* ═══════════════════════════════════════════════════
   ESTILOS GLOBALES FENIXBD
═══════════════════════════════════════════════════ */
* {
  box-sizing: border-box;
}

body {
  font-family: var(--ion-font-family);
  background: #f8fafc;
}

.page-content {
  padding: 12px 14px 80px;
}

/* ── Búsqueda ── */
.search-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  border: 0.5px solid #e2e8f0;
  border-radius: 10px;
  padding: 0 12px;
  height: 40px;
  margin-bottom: 10px;
}
.search-icon {
  color: #94a3b8;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  border: none;
  outline: none;
  background: transparent;
  font-size: 14px;
  color: #0f172a;
  font-family: inherit;
}
.search-input::placeholder {
  color: #94a3b8;
}

/* ── Categorías ── */
.cats-scroll {
  display: flex;
  gap: 6px;
  overflow-x: auto;
  margin-bottom: 12px;
  padding-bottom: 4px;
  scrollbar-width: none;
}
.cats-scroll::-webkit-scrollbar {
  display: none;
}
.cat-chip {
  white-space: nowrap;
  font-size: 12px;
  padding: 5px 12px;
  border-radius: 999px;
  border: 0.5px solid #e2e8f0;
  background: #fff;
  color: #64748b;
  cursor: pointer;
  flex-shrink: 0;
  font-family: inherit;
}
.cat-chip.active {
  background: #e11d48;
  color: #fff;
  border-color: #e11d48;
}

/* ── Grid productos ── */
.prod-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.prod-card {
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  overflow: hidden;
}
.prod-img {
  height: 80px;
  position: relative;
  background: #f8fafc;
  border-bottom: 0.5px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.prod-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.prod-img-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  width: 100%;
  height: 100%;
}
.prod-img-placeholder svg {
  color: #cbd5e1;
}
.stock-badge {
  position: absolute;
  top: 4px;
  left: 4px;
  font-size: 8px;
  font-weight: 600;
  padding: 2px 5px;
  border-radius: 4px;
}
.prod-info {
  padding: 8px 8px 10px;
}
.prod-cat {
  font-size: 9px;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.prod-name {
  font-size: 11px;
  font-weight: 500;
  color: #0f172a;
  margin: 2px 0;
  line-height: 1.3;
}
.prod-price {
  font-size: 12px;
  font-weight: 600;
  color: #e11d48;
}
.prod-unit {
  font-size: 9px;
  color: #94a3b8;
}
.add-btn {
  width: 100%;
  margin-top: 6px;
  height: 28px;
  border-radius: 7px;
  border: 0.5px solid rgba(225, 29, 72, 0.3);
  background: rgba(225, 29, 72, 0.08);
  color: #e11d48;
  font-size: 11px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}
.add-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

/* ── FAB carrito ── */
.cart-fab {
  position: fixed;
  bottom: 70px;
  right: 16px;
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: #e11d48;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(225, 29, 72, 0.4);
  z-index: 50;
}
.cart-fab-count {
  position: absolute;
  top: -2px;
  right: -2px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #1a1a2e;
  color: white;
  font-size: 9px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid white;
}

/* ── Clientes ── */
.cliente-card {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 12px;
  margin-bottom: 8px;
  cursor: pointer;
}
.cliente-card:active {
  background: #f8fafc;
}
.cl-avatar {
  width: 36px;
  height: 36px;
  border-radius: 9px;
  flex-shrink: 0;
  background: rgba(225, 29, 72, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 600;
  color: #e11d48;
}
.cl-info {
  flex: 1;
  min-width: 0;
}
.cl-name {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
}
.cl-biz {
  font-size: 11px;
  color: #64748b;
  margin-top: 1px;
}
.cl-address {
  font-size: 10px;
  color: #94a3b8;
  margin-top: 1px;
}
.cl-tags {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  margin-top: 5px;
}
.cl-tag {
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 999px;
  background: #f1f5f9;
  color: #64748b;
  border: 0.5px solid #e2e8f0;
}
.cl-tag.debt {
  background: rgba(239, 68, 68, 0.08);
  color: #991b1b;
  border-color: rgba(239, 68, 68, 0.2);
}
.cl-tag.credit {
  background: rgba(5, 150, 105, 0.08);
  color: #065f46;
  border-color: rgba(5, 150, 105, 0.2);
}
.cl-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 3px;
  flex-shrink: 0;
}
.cl-estado {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 999px;
  background: rgba(5, 150, 105, 0.1);
  color: #065f46;
}
.cl-freq {
  font-size: 10px;
  color: #94a3b8;
}
.cl-arrow {
  color: #cbd5e1;
  margin-top: 2px;
}

/* ── Carrito ── */
.cart-item {
  display: flex;
  gap: 10px;
  align-items: center;
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 10px;
  margin-bottom: 8px;
}
.ci-thumb {
  width: 44px;
  height: 44px;
  border-radius: 8px;
  flex-shrink: 0;
  background: #f8fafc;
  border: 0.5px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.ci-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.ci-thumb svg {
  color: #cbd5e1;
}
.ci-info {
  flex: 1;
  min-width: 0;
}
.ci-name {
  font-size: 12px;
  font-weight: 500;
  color: #0f172a;
}
.ci-unit {
  font-size: 10px;
  color: #94a3b8;
}
.ci-ctrl {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 6px;
}
.ci-btn {
  width: 24px;
  height: 24px;
  border-radius: 6px;
  border: 0.5px solid #e2e8f0;
  background: #f8fafc;
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f172a;
}
.ci-qty {
  font-size: 14px;
  font-weight: 500;
  color: #0f172a;
  min-width: 20px;
  text-align: center;
}
.ci-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}
.ci-unit-price {
  font-size: 11px;
  color: #64748b;
}
.ci-total {
  font-size: 12px;
  font-weight: 600;
  color: #e11d48;
}
.ci-delete {
  background: transparent;
  border: none;
  cursor: pointer;
  color: #94a3b8;
  padding: 2px;
}
.ci-delete:active {
  color: #dc2626;
}

.notas-box {
  background: #fff;
  border-radius: 12px;
  border: 0.5px dashed #e2e8f0;
  padding: 12px;
  margin-bottom: 8px;
}
.notas-lbl {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 500;
  color: #0f172a;
  margin-bottom: 6px;
}
.notas-lbl svg {
  color: #94a3b8;
}
.notas-input {
  width: 100%;
  border: none;
  outline: none;
  background: transparent;
  font-size: 13px;
  color: #0f172a;
  resize: none;
  font-family: inherit;
}
.notas-input::placeholder {
  color: #94a3b8;
}

.totales-box {
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 14px;
  margin-bottom: 10px;
}
.tot-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
  font-size: 13px;
}
.tot-row:last-child {
  margin-bottom: 0;
}
.tot-lbl {
  color: #64748b;
}
.tot-val {
  color: #0f172a;
}
.tot-val-green {
  color: #059669;
  margin-right: 4px;
}
.descuento-ctrl {
  display: flex;
  align-items: center;
}
.descuento-input {
  width: 60px;
  border: 0.5px solid #e2e8f0;
  border-radius: 6px;
  padding: 2px 6px;
  text-align: right;
  font-size: 13px;
  color: #059669;
  outline: none;
  background: #f0fdf4;
}
.tot-total {
  border-top: 0.5px solid #e2e8f0;
  padding-top: 8px;
  margin-top: 4px;
  font-size: 15px;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 0;
}
.total-amount {
  font-size: 16px;
  font-weight: 700;
  color: #e11d48;
}

.btn-confirmar {
  width: 100%;
  height: 50px;
  border-radius: 14px;
  border: none;
  background: #e11d48;
  color: white;
  font-size: 15px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 16px;
}
.btn-confirmar:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}
.btn-agregar-prods {
  height: 38px;
  padding: 0 20px;
  border-radius: 10px;
  border: 0.5px solid rgba(225, 29, 72, 0.3);
  background: rgba(225, 29, 72, 0.08);
  color: #e11d48;
  font-size: 13px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
}

/* ── Dashboard ── */
.greet-section {
  margin-bottom: 14px;
}
.greet-title {
  font-size: 18px;
  font-weight: 500;
  color: #0f172a;
  margin: 0 0 2px;
}
.greet-sub {
  font-size: 12px;
  color: #64748b;
  margin: 0;
}
.sales-card {
  background: linear-gradient(135deg, #e11d48 0%, #9f1239 100%);
  border-radius: 14px;
  padding: 16px;
  margin-bottom: 12px;
  color: white;
}
.sc-label {
  font-size: 10px;
  opacity: 0.75;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.sc-amount {
  font-size: 28px;
  font-weight: 600;
  letter-spacing: -0.5px;
  margin: 4px 0;
}
.sc-delta {
  font-size: 11px;
  display: flex;
  align-items: center;
  gap: 4px;
  opacity: 0.85;
}
.sc-delta.positivo {
  color: #86efac;
}
.sc-delta.negativo {
  color: #fca5a5;
}
.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 14px;
}
.quick-btn {
  border-radius: 10px;
  padding: 12px 10px;
  display: flex;
  align-items: center;
  gap: 8px;
  border: 0.5px solid;
  cursor: pointer;
  font-size: 12px;
  font-weight: 500;
  font-family: inherit;
  color: #0f172a;
  background: none;
}
.quick-red {
  background: rgba(225, 29, 72, 0.08);
  border-color: rgba(225, 29, 72, 0.2);
}
.quick-red svg {
  color: #e11d48;
}
.quick-blue {
  background: rgba(37, 99, 235, 0.08);
  border-color: rgba(37, 99, 235, 0.2);
}
.quick-blue svg {
  color: #2563eb;
}
.section-hdr {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}
.section-title {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
}
.section-link {
  font-size: 11px;
  color: #e11d48;
  background: none;
  border: none;
  cursor: pointer;
  font-family: inherit;
}
.pedido-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 0.5px solid #e2e8f0;
}
.pedido-card:last-child {
  border-bottom: none;
}
.pc-nombre {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
}
.pc-time {
  font-size: 10px;
  color: #94a3b8;
  margin-top: 2px;
}
.pc-amount {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
  text-align: right;
}
.pc-status {
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 999px;
  font-weight: 500;
}

/* ── Cliente detalle ── */
.detalle-header {
  display: flex;
  align-items: center;
  gap: 12px;
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 14px;
  margin-bottom: 10px;
}
.dh-avatar {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  flex-shrink: 0;
  background: rgba(225, 29, 72, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  color: #e11d48;
}
.dh-info {
  flex: 1;
}
.dh-name {
  font-size: 15px;
  font-weight: 500;
  color: #0f172a;
}
.dh-biz {
  font-size: 12px;
  color: #64748b;
  margin-top: 2px;
}
.dh-estado {
  display: inline-block;
  margin-top: 4px;
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 999px;
  background: rgba(5, 150, 105, 0.1);
  color: #065f46;
}
.accion-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-bottom: 10px;
}
.accion-btn {
  border-radius: 10px;
  padding: 10px 6px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  border: 0.5px solid;
  cursor: pointer;
  font-size: 11px;
  font-weight: 500;
  font-family: inherit;
  background: none;
}
.accion-red {
  background: rgba(225, 29, 72, 0.08);
  border-color: rgba(225, 29, 72, 0.2);
  color: #e11d48;
}
.accion-red svg {
  color: #e11d48;
}
.accion-green {
  background: rgba(5, 150, 105, 0.08);
  border-color: rgba(5, 150, 105, 0.2);
  color: #065f46;
}
.accion-green svg {
  color: #059669;
}
.accion-blue {
  background: rgba(37, 99, 235, 0.08);
  border-color: rgba(37, 99, 235, 0.2);
  color: #1e40af;
}
.accion-blue svg {
  color: #2563eb;
}

.info-card {
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 14px;
  margin-bottom: 10px;
}
.ic-header {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #94a3b8;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.ic-header.ic-danger {
  color: #dc2626;
}
.ic-value {
  font-size: 20px;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 4px;
}
.ic-value.danger {
  color: #dc2626;
}
.ic-sub {
  font-size: 11px;
  color: #64748b;
}
.ic-row {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 13px;
  color: #0f172a;
  margin-bottom: 8px;
}
.ic-row:last-child {
  margin-bottom: 0;
}
.ic-row svg {
  color: #94a3b8;
  flex-shrink: 0;
  margin-top: 2px;
}
.ic-ref {
  color: #64748b;
  font-size: 12px;
}
.ic-kv {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  font-size: 13px;
}
.ic-kv:last-child {
  margin-bottom: 0;
}
.ic-k {
  color: #64748b;
}
.ic-v {
  font-weight: 500;
  color: #0f172a;
  text-align: right;
}
.ic-notas {
  font-size: 13px;
  color: #64748b;
  margin: 0;
  line-height: 1.5;
}

/* ── Ventas lista ── */
.pedido-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 12px;
  margin-bottom: 8px;
  cursor: pointer;
}
.pedido-item:active {
  background: #f8fafc;
}
.pi-left {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  flex: 1;
}
.pi-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4px;
}
.pi-numero {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
}
.pi-cliente {
  font-size: 12px;
  color: #64748b;
  margin-top: 1px;
}
.pi-fecha {
  font-size: 10px;
  color: #94a3b8;
  margin-top: 2px;
}
.pi-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}
.pi-total {
  font-size: 13px;
  font-weight: 600;
  color: #0f172a;
}
.pi-estado {
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 999px;
  font-weight: 500;
}
.pi-cancel {
  background: transparent;
  border: none;
  cursor: pointer;
  color: #94a3b8;
  padding: 2px;
}
.pi-cancel:active {
  color: #dc2626;
}

/* ── Venta detalle ── */
.vd-header {
  align-items: center;
  justify-content: space-between;
}
.dh-numero {
  font-size: 16px;
  font-weight: 600;
  color: #0f172a;
}
.dh-fecha {
  font-size: 11px;
  color: #94a3b8;
  margin-top: 2px;
}
.vd-estado {
  font-size: 11px;
  font-weight: 500;
  padding: 4px 10px;
  border-radius: 999px;
}
.vd-prod-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 0.5px solid #f1f5f9;
}
.vd-prod-row:last-child {
  border-bottom: none;
}
.vd-prod-info {
  display: flex;
  gap: 8px;
  align-items: flex-start;
  flex: 1;
}
.vd-prod-qty {
  font-size: 14px;
  font-weight: 600;
  color: #e11d48;
  flex-shrink: 0;
}
.vd-prod-name {
  font-size: 12px;
  font-weight: 500;
  color: #0f172a;
}
.vd-prod-pres {
  font-size: 10px;
  color: #94a3b8;
}
.vd-prod-price {
  text-align: right;
  flex-shrink: 0;
}
.vd-pu {
  font-size: 10px;
  color: #64748b;
}
.vd-sub {
  font-size: 12px;
  font-weight: 600;
  color: #0f172a;
}
.vd-acciones {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 4px;
}
.btn-pdf {
  width: 100%;
  height: 46px;
  border-radius: 12px;
  border: 0.5px solid rgba(37, 99, 235, 0.3);
  background: rgba(37, 99, 235, 0.08);
  color: #2563eb;
  font-size: 14px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.btn-cancelar {
  width: 100%;
  height: 46px;
  border-radius: 12px;
  border: 0.5px solid rgba(220, 38, 38, 0.25);
  background: rgba(220, 38, 38, 0.06);
  color: #dc2626;
  font-size: 14px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

/* ── Skeleton ── */
.prod-skeleton,
.cliente-skeleton,
.skeleton-row {
  background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s infinite;
  border-radius: 12px;
}
.prod-skeleton {
  height: 160px;
}
.cliente-skeleton {
  height: 72px;
  margin-bottom: 8px;
}
.skeleton-row {
  height: 44px;
  margin-bottom: 6px;
}
@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* ── Empty states ── */
.empty-full,
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  gap: 12px;
}
.empty-full svg,
.empty-cart svg {
  color: #cbd5e1;
}
.empty-full p,
.empty-cart p {
  font-size: 14px;
  color: #94a3b8;
  margin: 0;
}

/* ── Toast ── */
.fenix-toast {
  --background: #1a1a2e;
  --color: #ffffff;
  --border-radius: 10px;
}
.fenix-alert {
  --background: #ffffff;
  --border-radius: 14px;
}

// ── Productos lista (fila) ─────────────────────────────────────
.prod-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.prod-row {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 10px;
  cursor: pointer;
  &:active {
    background: #f8fafc;
  }
}
.prod-inactivo {
  opacity: 0.5;
}
.pr-thumb {
  width: 44px;
  height: 44px;
  border-radius: 8px;
  flex-shrink: 0;
  background: #f8fafc;
  border: 0.5px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.pr-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.pr-info {
  flex: 1;
  min-width: 0;
}
.pr-nombre {
  font-size: 12px;
  font-weight: 500;
  color: #0f172a;
}
.pr-cat {
  font-size: 10px;
  color: #94a3b8;
  margin-top: 1px;
}
.pr-stock {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 3px;
}
.pr-stock-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.pr-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}
.pr-precio {
  font-size: 12px;
  font-weight: 600;
  color: #e11d48;
}
.pr-actions {
  display: flex;
  gap: 4px;
}
.pr-btn {
  width: 26px;
  height: 26px;
  border-radius: 6px;
  border: 0.5px solid #e2e8f0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}
.pr-btn-edit {
  color: #2563eb;
  border-color: rgba(37, 99, 235, 0.2);
  background: rgba(37, 99, 235, 0.06);
}
.pr-btn-danger {
  color: #dc2626;
  border-color: rgba(220, 38, 38, 0.2);
  background: rgba(220, 38, 38, 0.06);
}
.pr-btn-success {
  color: #059669;
  border-color: rgba(5, 150, 105, 0.2);
  background: rgba(5, 150, 105, 0.06);
}

// ── Bottom sheet (modal detalle producto) ──────────────────────
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 90;
}
.bottom-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 20px 20px 0 0;
  z-index: 95;
  max-height: 85vh;
  overflow-y: auto;
  padding-bottom: env(safe-area-inset-bottom);
}
.bs-handle {
  width: 36px;
  height: 4px;
  border-radius: 2px;
  background: #e2e8f0;
  margin: 10px auto 0;
}
.bs-img {
  height: 160px;
  background: #f8fafc;
  border-bottom: 0.5px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.bs-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.bs-img-ph {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: #cbd5e1;
  font-size: 12px;
}
.bs-content {
  padding: 14px 16px 20px;
}
.bs-badges {
  display: flex;
  gap: 6px;
  margin-bottom: 8px;
}
.bs-cat {
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 999px;
  background: #f1f5f9;
  color: #64748b;
  border: 0.5px solid #e2e8f0;
}
.bs-estado {
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 999px;
  font-weight: 500;
}
.bs-estado.activo {
  background: rgba(5, 150, 105, 0.1);
  color: #065f46;
}
.bs-estado.inactivo {
  background: rgba(100, 116, 139, 0.1);
  color: #475569;
}
.bs-nombre {
  font-size: 16px;
  font-weight: 600;
  color: #0f172a;
  margin: 0 0 4px;
}
.bs-marca {
  font-size: 12px;
  color: #64748b;
  margin: 0 0 2px;
}
.bs-codigo {
  font-size: 11px;
  color: #94a3b8;
  margin: 0 0 10px;
}
.bs-stock {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 14px;
}
.bs-stock-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.bs-stock-num {
  font-size: 12px;
  color: #64748b;
  margin-left: 2px;
}
.bs-section {
  margin-top: 14px;
}
.bs-section-lbl {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #94a3b8;
  margin-bottom: 8px;
}
.bs-pres-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 0.5px solid #f1f5f9;
}
.bs-pres-row:last-child {
  border-bottom: none;
}
.bs-pres-nombre {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
}
.bs-pres-uds {
  font-size: 11px;
  color: #94a3b8;
}
.bs-pres-precio {
  font-size: 13px;
  font-weight: 600;
  color: #e11d48;
}
.bs-pres-mayoreo {
  font-size: 10px;
  color: #64748b;
}
.bs-close-btn {
  width: 100%;
  height: 44px;
  margin-top: 16px;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  background: #f8fafc;
  color: #64748b;
  font-size: 14px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
}

// ── Nueva venta: pasos ─────────────────────────────────────────
.pasos-indicator {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
}
.paso-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  flex-shrink: 0;
}
.paso-num {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: #e2e8f0;
  color: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 600;
  transition: all 0.2s;
}
.paso-lbl {
  font-size: 9px;
  color: #94a3b8;
}
.paso-item.activo .paso-num {
  background: #e11d48;
  color: white;
}
.paso-item.activo .paso-lbl {
  color: #e11d48;
  font-weight: 500;
}
.paso-item.completado .paso-num {
  background: #059669;
  color: white;
}
.paso-item.completado .paso-lbl {
  color: #059669;
}
.paso-linea {
  flex: 1;
  height: 1px;
  background: #e2e8f0;
  margin: 0 4px;
  margin-bottom: 12px;
  transition: background 0.2s;
}
.paso-linea.completado {
  background: #059669;
}

.cliente-seleccionado {
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(37, 99, 235, 0.06);
  border: 0.5px solid rgba(37, 99, 235, 0.2);
  border-radius: 8px;
  padding: 8px 12px;
  margin-bottom: 10px;
  font-size: 12px;
  font-weight: 500;
  color: #1e40af;
}
.cliente-seleccionado svg {
  color: #2563eb;
  flex-shrink: 0;
}
.cs-cambiar {
  margin-left: auto;
  font-size: 11px;
  color: #2563eb;
  background: none;
  border: none;
  cursor: pointer;
  font-family: inherit;
}

.nv-prod-row {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 10px;
  margin-bottom: 6px;
}
.nv-prod-row.sin-stock {
  opacity: 0.5;
}
.nv-prod-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
  flex-shrink: 0;
}
.nv-add-btn {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  background: #e11d48;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nv-add-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.btn-volver-prods {
  width: 100%;
  height: 40px;
  border-radius: 12px;
  margin-top: 8px;
  border: 0.5px solid rgba(225, 29, 72, 0.25);
  background: rgba(225, 29, 72, 0.06);
  color: #e11d48;
  font-size: 13px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}

// ── Clientes módulo ────────────────────────────────────────────
.toolbar-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}
.btn-nuevo-cliente {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  flex-shrink: 0;
  background: #e11d48;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lista-meta {
  font-size: 11px;
  color: #94a3b8;
  margin-bottom: 8px;
}
.cl-avatar.inactivo {
  background: rgba(100, 116, 139, 0.12);
  color: #64748b;
}
.text-inactive {
  opacity: 0.5;
}
.cl-tag.inactive {
  background: rgba(100, 116, 139, 0.1);
  color: #475569;
  border-color: rgba(100, 116, 139, 0.2);
}

// ── Formulario de cliente ──────────────────────────────────────
.form-section {
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 14px;
  margin-bottom: 10px;
}
.fs-title {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #94a3b8;
  margin-bottom: 12px;
}
.fld {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 10px;
}
.fld:last-child {
  margin-bottom: 0;
}
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.flbl {
  font-size: 12px;
  font-weight: 500;
  color: #0f172a;
}
.req {
  color: #dc2626;
}
.finp,
.fsel {
  height: 40px;
  padding: 0 12px;
  border-radius: 10px;
  border: 0.5px solid #e2e8f0;
  background: #f8fafc;
  color: #0f172a;
  font-size: 14px;
  outline: none;
  font-family: inherit;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.finp:focus,
.fsel:focus {
  border-color: rgba(225, 29, 72, 0.4);
  box-shadow: 0 0 0 3px rgba(225, 29, 72, 0.08);
}
.finp-err {
  border-color: #dc2626 !important;
}
.ferr {
  font-size: 11px;
  color: #dc2626;
}
.finp-area {
  width: 100%;
  padding: 10px 12px;
  border-radius: 10px;
  border: 0.5px solid #e2e8f0;
  background: #f8fafc;
  color: #0f172a;
  font-size: 14px;
  outline: none;
  font-family: inherit;
  resize: none;
  transition: border-color 0.15s;
}
.finp-area:focus {
  border-color: rgba(225, 29, 72, 0.4);
  box-shadow: 0 0 0 3px rgba(225, 29, 72, 0.08);
}
.fld-check {
  display: flex;
  align-items: center;
}
.flbl-check {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: #0f172a;
  cursor: pointer;
}
.finp-check {
  width: 18px;
  height: 18px;
  border-radius: 4px;
  accent-color: #e11d48;
  cursor: pointer;
}

// ── Cliente detalle header con botón editar ────────────────────
.dh-edit-btn {
  width: 34px;
  height: 34px;
  border-radius: 9px;
  flex-shrink: 0;
  border: 0.5px solid rgba(37, 99, 235, 0.25);
  background: rgba(37, 99, 235, 0.08);
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  margin-left: auto;
}

// ── estadoColor helper (usar inline) ──────────────────────────
// Usado en cliente-detalle para colorear estado de pedidos

// ── Ubicación en formulario ────────────────────────────────────
.ubicacion-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 12px 0 8px;
}
.ub-txt {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
  margin: 0;
}
.ub-sub {
  font-size: 11px;
  color: #94a3b8;
  text-align: center;
  margin: 0;
}

.ubicacion-preview {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(5, 150, 105, 0.06);
  border: 0.5px solid rgba(5, 150, 105, 0.2);
  border-radius: 10px;
  padding: 10px 12px;
  margin-bottom: 10px;
}
.ub-coords {
  display: flex;
  gap: 6px;
  font-size: 12px;
  font-weight: 500;
  color: #0f172a;
  flex: 1;
}
.ub-ok {
  font-size: 10px;
  color: #059669;
  white-space: nowrap;
}

.btn-abrir-mapa {
  width: 100%;
  height: 42px;
  border-radius: 10px;
  border: 0.5px solid rgba(225, 29, 72, 0.28);
  background: rgba(225, 29, 72, 0.07);
  color: #e11d48;
  font-size: 13px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 4px;
}

// ── Selector de vehículo en nueva venta ────────────────────────
.vehiculo-section {
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 12px;
  margin-bottom: 8px;
}
.vs-title {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 500;
  color: #0f172a;
  margin-bottom: 10px;
  svg {
    color: #64748b;
  }
}
.vs-opcional {
  font-size: 10px;
  color: #94a3b8;
  font-weight: 400;
  margin-left: 2px;
}

.vs-selected {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(37, 99, 235, 0.06);
  border: 0.5px solid rgba(37, 99, 235, 0.2);
  border-radius: 10px;
  padding: 10px 12px;
}
.vs-info {
  flex: 1;
}
.vs-matricula {
  font-size: 13px;
  font-weight: 600;
  color: #0f172a;
}
.vs-detalle {
  font-size: 11px;
  color: #64748b;
  margin-top: 1px;
}
.vs-quitar {
  background: transparent;
  border: none;
  cursor: pointer;
  color: #94a3b8;
  padding: 4px;
  &:active {
    color: #dc2626;
  }
}

.vs-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.vs-loading {
  font-size: 12px;
  color: #94a3b8;
  text-align: center;
  padding: 8px;
}
.vs-empty {
  font-size: 12px;
  color: #94a3b8;
  text-align: center;
  padding: 8px;
}

.vs-item {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #f8fafc;
  border-radius: 10px;
  border: 0.5px solid #e2e8f0;
  padding: 10px 12px;
  cursor: pointer;
  width: 100%;
  text-align: left;
  font-family: inherit;
  &:active {
    background: #f1f5f9;
  }
}
.vs-item-icon {
  width: 36px;
  height: 36px;
  border-radius: 9px;
  flex-shrink: 0;
  background: rgba(37, 99, 235, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  svg {
    color: #2563eb;
  }
}
.vs-item-info {
  flex: 1;
  min-width: 0;
}
.vs-item-matricula {
  font-size: 13px;
  font-weight: 600;
  color: #0f172a;
}
.vs-item-detalle {
  font-size: 11px;
  color: #64748b;
  margin-top: 1px;
}

// ── Método de pago ──
.metodo-pago-section {
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 12px;
  margin-bottom: 8px;
}
.mp-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
}
.mp-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  border-radius: 10px;
  border: 0.5px solid #e2e8f0;
  background: #f8fafc;
  color: #64748b;
  font-size: 12px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.15s;
}
.mp-btn.activo {
  background: rgba(225, 29, 72, 0.08);
  border-color: rgba(225, 29, 72, 0.3);
  color: #e11d48;
}
.mp-btn.activo svg {
  color: #e11d48;
}
.mp-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.mp-warning {
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(217, 119, 6, 0.08);
  border: 0.5px solid rgba(217, 119, 6, 0.2);
  border-radius: 8px;
  padding: 6px 10px;
  margin-top: 8px;
  font-size: 11px;
  color: #92400e;
}

// ── Selector de repartidor ─────────────────────────────────────
.repartidor-section {
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 12px;
  margin-bottom: 8px;
}

.rep-selected {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(124, 58, 237, 0.06);
  border: 0.5px solid rgba(124, 58, 237, 0.2);
  border-radius: 10px;
  padding: 10px 12px;
}
.rep-avatar {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  flex-shrink: 0;
  background: rgba(124, 58, 237, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  color: #7c3aed;
}
.rep-avatar-small {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  flex-shrink: 0;
  background: rgba(124, 58, 237, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 600;
  color: #7c3aed;
}
.rep-info {
  flex: 1;
  min-width: 0;
}
.rep-name {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
}
.rep-tel {
  font-size: 11px;
  color: #64748b;
  margin-top: 1px;
}

.rep-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.rep-item {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #f8fafc;
  border-radius: 10px;
  border: 0.5px solid #e2e8f0;
  padding: 8px 12px;
  cursor: pointer;
  width: 100%;
  text-align: left;
  font-family: inherit;
  &:active {
    background: #f1f5f9;
  }
}

// ═════════════════════════════════════════════════════════════
// REPARTIDOR — Stats y lista
// ═════════════════════════════════════════════════════════════

.rep-stats {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px;
  margin-bottom: 12px;
}
.rep-stat-card {
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 14px 8px;
  text-align: center;
}
.rs-num {
  font-size: 22px;
  font-weight: 600;
}
.rs-lbl {
  font-size: 10px;
  color: #64748b;
  margin-top: 2px;
}

.btn-mapa {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  padding: 14px;
  margin-bottom: 14px;
  background: #fff;
  border: 0.5px solid #e2e8f0;
  border-radius: 12px;
  cursor: pointer;
  font-family: inherit;
}
.bm-icon {
  width: 38px;
  height: 38px;
  border-radius: 9px;
  flex-shrink: 0;
  background: linear-gradient(135deg, #e11d48 0%, #9f1239 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.bm-text {
  flex: 1;
  text-align: left;
}
.bm-title {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
}
.bm-sub {
  font-size: 11px;
  color: #64748b;
  margin-top: 1px;
}

// ── Tarjeta de entrega ─────────────────────────────────────────
.entrega-card {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  background: #fff;
  border-radius: 12px;
  border: 0.5px solid #e2e8f0;
  padding: 12px;
  margin-bottom: 8px;
  cursor: pointer;
  &:active {
    background: #f8fafc;
  }
}
.ec-num-badge {
  width: 30px;
  height: 30px;
  border-radius: 9px;
  flex-shrink: 0;
  background: rgba(225, 29, 72, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  color: #e11d48;
}
.ec-info {
  flex: 1;
  min-width: 0;
}
.ec-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.ec-pedido {
  font-size: 12px;
  font-weight: 600;
  color: #0f172a;
}
.ec-estado {
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 999px;
  font-weight: 500;
}
.ec-cliente {
  font-size: 14px;
  font-weight: 500;
  color: #0f172a;
  margin-top: 3px;
}
.ec-direccion {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  color: #64748b;
  margin-top: 3px;
}
.ec-direccion svg {
  color: #94a3b8;
  flex-shrink: 0;
}
.ec-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10px;
  gap: 8px;
}
.ec-total {
  font-size: 14px;
  font-weight: 600;
  color: #e11d48;
}
.ec-actions {
  display: flex;
  gap: 6px;
}
.ec-action {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  background: #f8fafc;
  border: 0.5px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.15s;
  &:active {
    transform: scale(0.95);
  }
  &:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
}
.ec-call {
  color: #059669;
}
.ec-wa {
  color: #22c55e;
}
.ec-nav {
  color: white;
  background: #2563eb;
  border-color: #2563eb;
  &:disabled {
    background: #94a3b8;
    border-color: #94a3b8;
  }
}

// ═════════════════════════════════════════════════════════════
// MAPA DE ENTREGAS
// ═════════════════════════════════════════════════════════════

.mapa-fullscreen-content {
  position: fixed;
  top: 56px; /* altura del navbar */
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
}

/* ✅ Panel info — más abajo del navbar y más compacto */
.mapa-info-panel {
  position: absolute;
  top: 14px; /* ← antes 70px, ahora relativo al content */
  left: 14px;
  background: rgba(255, 255, 255, 0.97);
  backdrop-filter: blur(8px);
  border-radius: 12px;
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 4px 12px rgba(15, 23, 42, 0.1);
  z-index: 100;
  max-width: calc(100% - 28px);
}
.mip-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  font-weight: 500;
  color: #0f172a;
  white-space: nowrap;
}
.mip-divider {
  width: 0.5px;
  height: 16px;
  background: #e2e8f0;
}

/* ✅ Botón iniciar ruta — abajo, centrado, encima del strip */
.btn-iniciar-ruta {
  position: absolute;
  bottom: calc(90px + env(safe-area-inset-bottom)) !important;
  left: 50%;
  transform: translateX(-50%);
  width: max-content; /* ✅ AGREGAR — evita estirarse */
  height: 46px;
  padding: 0 22px;
  border-radius: 23px;
  background: #e11d48;
  color: white;
  border: none;
  font-size: 14px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 6px 18px rgba(225, 29, 72, 0.45);
  z-index: 100;
  white-space: nowrap; /* ✅ AGREGAR — no romper el texto */
  background: #E11D48;
  box-shadow: 0 6px 18px rgba(225, 29, 72, 0.45);
}
.btn-iniciar-ruta,
.btn-terminar-ruta,
.entregas-strip,
.fab-pdf {
  bottom: calc(
    var(--bottom-base, 16px) + env(safe-area-inset-bottom)
  ) !important;
}

.btn-iniciar-ruta,
.btn-terminar-ruta {
  position: absolute;
  // ✅ Mover los botones POR ENCIMA del tabbar + safe area
  bottom: calc(90px + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  width: max-content;
  height: 46px;
  padding: 0 22px;
  border-radius: 23px;
  color: white;
  border: none;
  font-size: 14px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  z-index: 100;
  white-space: nowrap;
}
.btn-terminar-ruta {
  position: absolute;
  bottom: calc(90px + env(safe-area-inset-bottom)) !important;
  left: 50%;
  transform: translateX(-50%);
  width: max-content; /* ✅ AGREGAR */
  height: 46px;
  padding: 0 22px;
  border-radius: 23px;
  background: #dc2626;
  color: white;
  border: none;
  font-size: 14px;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 6px 18px rgba(220, 38, 38, 0.45);
  z-index: 100;
  white-space: nowrap; /* ✅ AGREGAR */
  background: #DC2626;
  box-shadow: 0 6px 18px rgba(220, 38, 38, 0.45);
}

/* Strip de entregas — sin cambios pero recordatorio */
.entregas-strip {
  position: absolute;
  bottom: calc(16px + env(safe-area-inset-bottom)); 
  left: 0;
  right: 0;
  display: flex;
  gap: 8px;
  padding: 0 12px;
  overflow-x: auto;
  scrollbar-width: none;
  z-index: 90; /* ← menor que el botón */
  padding-bottom: env(safe-area-inset-bottom);
}
.entregas-strip::-webkit-scrollbar {
  display: none;
}

.es-item {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255, 255, 255, 0.97);
  backdrop-filter: blur(8px);
  border-radius: 12px;
  padding: 9px 10px 9px 9px;
  min-width: 230px;
  cursor: pointer;
  box-shadow: 0 4px 12px rgba(15, 23, 42, 0.1);
}
.es-num {
  width: 26px;
  height: 26px;
  border-radius: 7px;
  background: #e11d48;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 600;
  flex-shrink: 0;
}
.es-info {
  flex: 1;
  min-width: 0;
}
.es-cliente {
  font-size: 12px;
  font-weight: 500;
  color: #0f172a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.es-total {
  font-size: 11px;
  color: #e11d48;
  font-weight: 600;
  margin-top: 1px;
}
.es-nav-btn {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  flex-shrink: 0;
  background: #2563eb;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mapa-loading,
.mapa-empty {
  position: absolute;
  inset: 56px 0 0 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 24px;
  background: rgba(248, 250, 252, 0.85);
  z-index: 50;
}
.ml-spinner {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 3px solid #e2e8f0;
  border-top-color: #e11d48;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
.mapa-empty p {
  color: #94a3b8;
  font-size: 14px;
  margin: 0;
  text-align: center;
}
.me-sub {
  font-size: 11px;
}

// ═════════════════════════════════════════════════════════════
// MARKERS LEAFLET PERSONALIZADOS
// ═════════════════════════════════════════════════════════════
// Estos deben ir SIN :host porque Leaflet inyecta en body

.custom-marker-wrapper {
  background: transparent !important;
  border: none !important;
}

.num-marker {
  width: 34px;
  height: 42px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.num-marker::before {
  content: "";
  position: absolute;
  inset: 0;
  background: #e11d48;
  clip-path: path(
    "M17 0C7.6 0 0 7.6 0 17c0 12 17 25 17 25s17-13 17-25c0-9.4-7.6-17-17-17z"
  );
}
.num-marker span {
  position: relative;
  z-index: 1;
  color: white;
  font-size: 13px;
  font-weight: 700;
  margin-top: -10px; /* compensar la cola del pin */
}

.mi-marker {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #2563eb;
  border: 3px solid white;
  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.3);
  position: relative;
}
.mi-pulse {
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  background: rgba(37, 99, 235, 0.3);
  animation: pulse 1.6s ease-in-out infinite;
}
@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 0.6;
  }
  100% {
    transform: scale(2.5);
    opacity: 0;
  }
}

.mini-mapa-btn {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  padding: 12px;
  margin-bottom: 14px;
  background: #fff;
  border: 0.5px solid #e2e8f0;
  border-radius: 12px;
  cursor: pointer;
  font-family: inherit;
}
.mm-preview {
  width: 56px;
  height: 56px;
  border-radius: 10px;
  flex-shrink: 0;
  background: linear-gradient(135deg, #e11d48 0%, #9f1239 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.mm-info {
  flex: 1;
  text-align: left;
}
.mm-title {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
}
.mm-sub {
  font-size: 11px;
  color: #64748b;
  margin-top: 2px;
}

.empty-state {
  padding: 20px;
  text-align: center;
  color: #94a3b8;
  font-size: 13px;
}

// Botón rectangular "Mis reportes" del dashboard
.btn-reportes-rect {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  padding: 12px;
  margin-bottom: 14px;
  background: #fff;
  border: 0.5px solid #e2e8f0;
  border-radius: 12px;
  cursor: pointer;
  font-family: inherit;
}
.brr-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.brr-info {
  flex: 1;
  text-align: left;
}
.brr-title {
  font-size: 13px;
  font-weight: 500;
  color: #0f172a;
}
.brr-sub {
  font-size: 11px;
  color: #64748b;
  margin-top: 2px;
}

// Botón mini en mis-entregas
.btn-mini-reportes {
  display: flex;
  align-items: center;
  gap: 6px;
  width: 100%;
  height: 38px;
  margin-bottom: 12px;
  background: rgba(124, 58, 237, 0.06);
  border: 0.5px solid rgba(124, 58, 237, 0.2);
  border-radius: 10px;
  padding: 0 14px;
  font-size: 12px;
  font-weight: 500;
  color: #7c3aed;
  font-family: inherit;
  cursor: pointer;
  justify-content: center;
}

.link-btn {
  background: none;
  border: none;
  color: #2563eb;
  font-size: 11px;
  font-weight: 500;
  cursor: pointer;
  font-family: inherit;
}

ion-content {
  --ion-safe-area-bottom: env(safe-area-inset-bottom);
  --ion-safe-area-top: env(safe-area-inset-top);
}
.tabbar,
app-tabbar {
  padding-bottom: env(safe-area-inset-bottom);
  // si tu tabbar tiene posición fija, también:
  bottom: 0;
}
